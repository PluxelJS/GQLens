{
  "name": "gqlens",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "lint": "oxlint -c oxlint.config.mts --deny-warnings --report-unused-disable-directives packages",
    "format": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "verify": "npm run lint && npm run format && turbo run typecheck build test"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tsdown": "^0.22.0",
    "turbo": "^2.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=24.12"
  },
  "packageManager": "npm@11.13.0"
}
