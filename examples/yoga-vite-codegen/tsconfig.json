{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "paths": {
      "@gqlens/core": ["../../packages/core/src/index.ts"],
      "@gqlens/core/codegen": ["../../packages/core/codegen/index.ts"],
      "@gqlens/react": ["../../packages/react/src/index.tsx"]
    },
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src", "web", "test", "tooling", "vite.config.ts"]
}
