{
  "name": "gqlens-yoga-vite-codegen-example",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "tsx tooling/generate-gqlens.ts",
    "dev": "vite",
    "dev:client": "GRAPHQL_PROXY_TARGET=http://127.0.0.1:4000 vite",
    "dev:server": "tsx src/server.ts",
    "build": "vite build",
    "typecheck": "pnpm run codegen && tsc --noEmit",
    "test": "pnpm run codegen && tsx test/frontend-contract.ts && tsx test/smoke.ts",
    "verify": "pnpm run codegen && tsc --noEmit && tsx test/frontend-contract.ts && tsx test/smoke.ts && vite build"
  },
  "dependencies": {
    "@elysiajs/node": "^1.4.5",
    "@gqlens/core": "file:../../packages/core",
    "@gqlens/react": "file:../../packages/react",
    "@gqlens/vite": "file:../../packages/vite",
    "@logtape/logtape": "^2.2.3",
    "elysia": "^1.4.29",
    "graphql": "^16.14.2",
    "graphql-yoga": "^5.21.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "engines": {
    "node": ">=24.12"
  },
  "packageManager": "pnpm@11.5.2"
}
