{
  "name": "@gqlens/core",
  "version": "0.3.0",
  "description": "Core GQLens library — query parsing and lens engine.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/PluxelJS/GQLens",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./codegen": {
      "development": "./codegen/index.ts",
      "default": "./dist/codegen.js"
    },
    "./oxlint": {
      "development": "./oxlint/index.ts",
      "default": "./dist/oxlint.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./codegen": "./dist/codegen.js",
      "./oxlint": "./dist/oxlint.js",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsdown"
  },
  "dependencies": {
    "alien-signals": "^3.2"
  },
  "engines": {
    "node": ">=24.12"
  }
}
