{
  "name": "@gqlens/codegen",
  "version": "0.3.0",
  "description": "GQLens schema codegen — generates typed accessors, schema contract, and invalidation specs.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/PluxelJS/GQLens",
    "directory": "packages/codegen"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsdown",
    "update-fixtures": "npm run build && node scripts/update-fixtures.mjs"
  },
  "dependencies": {
    "@graphql-codegen/core": "^4.0.2",
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/visitor-plugin-common": "^5.8.0",
    "code-block-writer": "^13.0.3"
  },
  "devDependencies": {
    "graphql": "^16"
  },
  "peerDependencies": {
    "@gqlens/core": "workspace:*",
    "graphql": "^16"
  },
  "engines": {
    "node": ">=24.12"
  }
}
