{
  "name": "@gqlens/vite",
  "version": "0.3.0",
  "description": "GQLens Vite plugin for schema codegen and GraphQL dev middleware.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/PluxelJS/GQLens",
    "directory": "packages/vite"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./entry": {
      "development": "./src/entry.ts",
      "default": "./dist/entry.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./entry": "./dist/entry.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsdown"
  },
  "dependencies": {
    "@gqlens/codegen": "workspace:*"
  },
  "devDependencies": {
    "@gqlens/core": "workspace:*",
    "graphql": "^16",
    "vite": "^8"
  },
  "peerDependencies": {
    "@gqlens/core": "workspace:*",
    "graphql": "^16",
    "vite": "^8"
  },
  "engines": {
    "node": ">=24.12"
  }
}
